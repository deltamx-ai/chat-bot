{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chat-bot",
  "version": "0.1.0",
  "identifier": "com.maxai.chatbot",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "chat-bot",
        "width": 1440,
        "height": 960
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
