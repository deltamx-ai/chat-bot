{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "CI=false tauri dev",
    "web:dev": "vite",
    "build": "vite build",
    "web:build": "vite build",
    "tauri:dev": "CI=false tauri dev",
    "tauri:build": "CI=false tauri build",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{json,js,ts,md}\" \"src-tauri/**/*.{toml,rs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{json,js,ts,md}\" \"src-tauri/**/*.json\"",
    "preview": "vite preview",
    "cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@tauri-apps/api": "^2.8.0",
    "swr": "^2.3.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
